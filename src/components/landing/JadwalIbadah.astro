---
---

<!-- Jadwal Ibadah - Asymmetric Grid -->
<section id="jadwal" class="py-32 bg-gray-900 relative overflow-hidden">
	<div class="absolute inset-0">
		<div class="absolute inset-0 bg-cover bg-center opacity-10" style="background-image: url('https://images.unsplash.com/photo-1507692049790-de58290a4334?w=1920&q=80');"></div>
	</div>
	<div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-slate-600/10 to-transparent"></div>
	
	<div class="container mx-auto px-6 relative">
		<div class="flex items-end gap-4 mb-16">
			<div class="flex-1">
				<h2 class="text-7xl md:text-9xl font-black text-gray-800 leading-none opacity-20">JADWAL</h2>
				<h3 class="text-4xl md:text-5xl font-bold text-white -mt-8 md:-mt-12">Ibadah Kami</h3>
			</div>
			<p class="text-gray-400 text-lg max-w-md hidden md:block">
				Bergabunglah bersama kami dalam setiap ibadah
			</p>
		</div>
		
		<div class="grid md:grid-cols-3 gap-6">
			<div class="md:col-span-2 bg-gradient-to-br from-slate-700 to-slate-800 rounded-3xl p-10 text-white transform hover:scale-105 transition-all duration-300 shadow-2xl">
				<div class="flex justify-between items-start mb-8">
					<div>
						<p class="text-slate-300 font-medium mb-2">IBADAH UMUM</p>
						<h4 class="text-5xl font-black">MINGGU</h4>
					</div>
					<div class="text-right">
						<p class="text-6xl font-black">07.00</p>
					</div>
				</div>
				<div class="flex items-center gap-2 text-slate-300">
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path></svg>
					<span>Setiap Minggu Pagi</span>
				</div>
			</div>
			
			<div class="bg-gradient-to-br from-gray-600 to-gray-700 rounded-3xl p-10 text-white transform hover:scale-105 transition-all duration-300 shadow-2xl">
				<div class="flex flex-col justify-between h-full">
					<div>
						<p class="text-gray-300 font-medium mb-2">YOUTH SERVICE</p>
						<h4 class="text-4xl font-black mb-4">SABTU</h4>
					</div>
					<p class="text-5xl font-black">18.00</p>
				</div>
			</div>
			
			<div class="bg-gradient-to-br from-zinc-600 to-zinc-700 rounded-3xl p-10 text-white transform hover:scale-105 transition-all duration-300 shadow-2xl">
				<div class="flex flex-col justify-between h-full">
					<div>
						<p class="text-zinc-300 font-medium mb-2">DOA PAGI</p>
						<h4 class="text-4xl font-black mb-4">SETIAP HARI</h4>
					</div>
					<p class="text-5xl font-black">05.00</p>
				</div>
			</div>
			
			<div class="md:col-span-2 bg-gray-800 rounded-3xl p-10 text-white border-2 border-gray-700 hover:border-slate-500 transition-colors">
				<h4 class="text-2xl font-bold mb-4">💡 Tips</h4>
				<p class="text-gray-400">Datang 15 menit sebelum ibadah dimulai untuk persiapan yang lebih baik.</p>
			</div>
		</div>
	</div>
</section>
