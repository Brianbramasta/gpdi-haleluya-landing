---
---

<!-- Hero Section -->
<section class="relative min-h-[60vh] overflow-hidden">
	<div class="absolute inset-0">
		<!-- Background Image -->
		<div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1529070538774-1843cb3265df?w=1920&q=80');"></div>
		<!-- Overlay Gradient -->
		<div class="absolute inset-0 bg-gradient-to-br from-gray-900/90 via-slate-800/85 to-gray-900/90"></div>
		<div class="absolute top-20 right-0 w-96 h-96 bg-slate-400 rounded-full blur-3xl opacity-20"></div>
		<div class="absolute bottom-20 left-0 w-96 h-96 bg-gray-400 rounded-full blur-3xl opacity-20"></div>
	</div>
	
	<div class="relative container mx-auto px-6 min-h-[60vh] flex items-center">
		<div class="text-white space-y-6 text-center max-w-4xl mx-auto">
			<div class="inline-block bg-white/20 backdrop-blur-sm px-6 py-2 rounded-full text-sm font-medium">
				Komunitas Rayon
			</div>
			<h1 class="text-5xl md:text-7xl font-black leading-tight tracking-tight">
				Ibadah Rayon
			</h1>
			<p class="text-xl md:text-2xl font-light text-white/90 max-w-2xl mx-auto">
				Bergabunglah dalam ibadah rayon untuk mempererat persekutuan dan bertumbuh bersama dalam iman
			</p>
		</div>
	</div>
</section>
