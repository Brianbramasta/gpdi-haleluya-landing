---
import { getJadwalIbadah } from '../../../lib/strapi';

const jadwalResponse = await getJadwalIbadah();
const jadwalList = jadwalResponse.data;

// Group jadwal by hari
const hariOrder = ['Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu', 'Minggu'];
const jadwalByHari = hariOrder.reduce((acc, hari) => {
	acc[hari] = jadwalList.filter((j: any) => j.hari === hari);
	return acc;
}, {} as Record<string, typeof jadwalList>);
---

<!-- Jadwal Ibadah - Asymmetric Grid -->
<section id="jadwal" class="py-32 bg-gray-900 relative overflow-hidden">
	<div class="absolute inset-0">
		<div class="absolute inset-0 bg-cover bg-center opacity-10" style="background-image: url('https://images.unsplash.com/photo-1507692049790-de58290a4334?w=1920&q=80');"></div>
	</div>
	<div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-slate-600/10 to-transparent"></div>
	
	<div class="container mx-auto px-6 relative">
		<div class="flex items-end gap-4 mb-16">
			<div class="flex-1">
				<h2 class="text-7xl md:text-9xl font-black text-gray-800 leading-none opacity-20">JADWAL</h2>
				<h3 class="text-4xl md:text-5xl font-bold text-white -mt-8 md:-mt-12">Ibadah Kami</h3>
			</div>
			<p class="text-gray-400 text-lg max-w-md hidden md:block">
				Bergabunglah bersama kami dalam setiap ibadah
			</p>
		</div>
		
		<div class="space-y-8">
			<!-- Doa Pagi Banner -->
			{jadwalByHari['Senin']?.length > 0 && (
				<div class="bg-gradient-to-r from-amber-600 to-amber-700 rounded-3xl p-8 text-white shadow-2xl">
					<div class="flex items-center gap-4">
						<div class="bg-white/20 p-4 rounded-2xl">
							<svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path></svg>
						</div>
						<div>
							<h4 class="text-2xl font-bold mb-1">{jadwalByHari['Senin'][0].keterangan || 'Doa Pagi'}</h4>
							<p class="text-amber-100">{jadwalByHari['Senin'][0].waktu}</p>
						</div>
					</div>
				</div>
			)}

			<!-- Weekly Schedule Grid -->
			<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
				{hariOrder.map((hari) => {
					const jadwalHari = jadwalByHari[hari];
					if (!jadwalHari || jadwalHari.length === 0) return null;
					
					const isMinggu = hari === 'Minggu';
					const gridClass = isMinggu ? 'md:col-span-2 lg:col-span-3' : '';
					const bgClass = {
						'Senin': 'from-amber-700 to-amber-800',
						'Selasa': 'from-slate-700 to-slate-800',
						'Rabu': 'from-gray-700 to-gray-800',
						'Kamis': 'from-zinc-700 to-zinc-800',
						'Jumat': 'from-stone-700 to-stone-800',
						'Sabtu': 'from-blue-700 to-blue-800',
						'Minggu': 'from-emerald-700 to-emerald-800'
					}[hari];
					
					return (
						<div class={`bg-gradient-to-br ${bgClass} rounded-3xl p-6 text-white transform hover:scale-105 transition-all duration-300 shadow-2xl ${gridClass}`}>
							<div class="text-center mb-4">
								<h4 class={`font-black ${isMinggu ? 'text-4xl mb-6' : 'text-3xl'}`}>{hari.toUpperCase()}</h4>
							</div>
							<div class={`${isMinggu ? 'grid md:grid-cols-2 lg:grid-cols-4 gap-4' : 'space-y-3'}`}>
								{jadwalHari.map((jadwal: any) => (
									<div class={`bg-white/10 rounded-xl ${isMinggu ? 'p-4' : jadwalHari.length > 3 ? 'p-2' : 'p-3'}`}>
										<p class={`font-bold ${isMinggu ? 'text-sm mb-1' : jadwalHari.length > 3 ? 'text-xs' : 'text-sm'}`}>{jadwal.nama_ibadah}</p>
										<p class={`text-slate-300 font-bold ${isMinggu ? 'text-2xl' : 'text-lg'}`}>{jadwal.waktu}</p>
									</div>
								))}
							</div>
						</div>
					);
				})}
			</div>

			<!-- Tips -->
			<div class="bg-gray-800 rounded-3xl p-8 text-white border-2 border-gray-700 hover:border-slate-500 transition-colors">
				<h4 class="text-2xl font-bold mb-3">💡 Tips</h4>
				<p class="text-gray-400">Datang 15 menit sebelum ibadah dimulai untuk persiapan yang lebih baik.</p>
			</div>
		</div>
	</div>
</section>
