---
import { getPengumuman, formatDate } from '../../../lib/strapi';

const pengumumanResponse = await getPengumuman();
const pengumumanList = pengumumanResponse.data;
---

<!-- Pengumuman - Horizontal Scroll Cards -->
<section class="py-32 bg-gradient-to-b from-gray-900 to-gray-800 relative overflow-hidden">
	<div class="absolute inset-0">
		<div class="absolute inset-0 bg-cover bg-center opacity-5" style="background-image: url('https://images.unsplash.com/photo-1511632765486-a01980e01a18?w=1920&q=80');"></div>
	</div>
	<div class="container mx-auto px-6">
		<div class="text-center mb-16">
			<h2 class="text-5xl md:text-7xl font-black text-white mb-4">PENGUMUMAN</h2>
			<p class="text-xl text-gray-400">Informasi terbaru untuk jemaat</p>
		</div>
		
		<div class="flex overflow-x-auto gap-6 pb-8 snap-x snap-mandatory scrollbar-hide">
			{pengumumanList.map((pengumuman: any, index: number) => {
				const bgClass = index % 3 === 0 ? 'from-slate-600 to-slate-700' : index % 3 === 1 ? 'from-gray-600 to-gray-700' : 'from-zinc-600 to-zinc-700';
				return (
					<div class={`min-w-[350px] md:min-w-[400px] bg-gradient-to-br ${bgClass} rounded-3xl p-8 snap-center transform hover:scale-105 transition-all duration-300 shadow-2xl`}>
						<div class="bg-white/20 backdrop-blur-sm rounded-full px-4 py-1 inline-block mb-4">
							<span class="text-white text-sm font-medium">{formatDate(pengumuman.tanggal)}</span>
						</div>
						<h3 class="text-2xl font-bold text-white mb-3">{pengumuman.judul}</h3>
						<p class="text-white/90">{pengumuman.deskripsi}</p>
					</div>
				);
			})}
		</div>
	</div>
</section>
