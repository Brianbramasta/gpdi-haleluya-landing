<!-- Event List Section -->
<section class="py-16 bg-white">
	<div class="container mx-auto px-6">
		<div class="max-w-6xl mx-auto">
			<div class="space-y-8">
				<!-- Event 1 -->
				<div class="bg-gray-50 rounded-3xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
					<div class="grid md:grid-cols-3">
						<div class="bg-slate-600 p-8 flex flex-col items-center justify-center text-white">
							<div class="text-5xl font-black">15</div>
							<div class="text-2xl font-bold">Juli</div>
							<div class="text-lg">2026</div>
						</div>
						<div class="md:col-span-2 p-8">
							<div class="inline-block bg-slate-100 text-slate-700 px-3 py-1 rounded-full text-sm font-medium mb-4">
								Ibadah Khusus
							</div>
							<h3 class="text-2xl font-black text-gray-800 mb-3">Ibadah Syukur Anniversary Gereja</h3>
							<p class="text-gray-600 mb-4">Merayakan ulang tahun gereja dengan ibadah syukur dan fellowship bersama seluruh jemaat.</p>
							<div class="flex flex-wrap gap-4 text-sm text-slate-600">
								<span class="flex items-center gap-2">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
									</svg>
									09.00 - 12.00 WIB
								</span>
								<span class="flex items-center gap-2">
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
									</svg>
									Gedung Gereja
								</span>
							</div>
						</div>
					</div>
				</div>
				
