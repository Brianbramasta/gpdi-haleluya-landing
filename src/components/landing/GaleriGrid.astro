---
import { getGaleri, getImageUrl } from '../../lib/strapi';

const galeriResponse = await getGaleri();
const galeriList = galeriResponse.data;

// Group galeri by kategori
const galeriByKategori = galeriList.reduce((acc: any, item: any) => {
	const kategori = item.kategori || 'Lainnya';
	if (!acc[kategori]) acc[kategori] = [];
	acc[kategori].push(item);
	return acc;
}, {});
---

<!-- Galeri Grid Section -->
<section class="py-16 bg-white">
	<div class="container mx-auto px-6">
		<div class="max-w-7xl mx-auto">
			{Object.entries(galeriByKategori).map(([kategori, items]) => {
				const galeriItems = items as any[];
				return (
				<div class="mb-16">
					<h2 class="text-3xl font-black text-gray-800 mb-8 flex items-center gap-3">
						<div class="w-12 h-1 bg-slate-600"></div>
						{kategori}
					</h2>
					<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
						{galeriItems.map((galeri: any) => (
							<div class="aspect-square bg-gray-200 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow">
								{galeri.gambar ? (
									<img src={getImageUrl(galeri.gambar)} alt={galeri.judul} class="w-full h-full object-cover" />
								) : (
									<div class="w-full h-full bg-gradient-to-br from-slate-400 to-slate-500 flex items-center justify-center">
										<svg class="w-16 h-16 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
										</svg>
									</div>
								)}
							</div>
						))}
					</div>
				</div>
				);
			})}
		</div>
	</div>
</section>
