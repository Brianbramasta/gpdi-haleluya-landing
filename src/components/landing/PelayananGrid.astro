---
---

<!-- Pelayanan Grid Section -->
<section class="py-16 bg-white">
	<div class="container mx-auto px-6">
		<div class="max-w-6xl mx-auto">
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
				<!-- Youth -->
				<div class="bg-gray-50 rounded-3xl p-8 hover:shadow-xl transition-all hover:-translate-y-1">
					<div class="w-16 h-16 bg-slate-600 rounded-2xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
						</svg>
					</div>
					<h3 class="text-2xl font-black text-gray-800 mb-3">Youth</h3>
					<p class="text-gray-600 mb-4">Komunitas pemuda yang dinamis, bertumbuh bersama dalam iman dan persahabatan.</p>
					<div class="text-sm text-slate-600 font-medium">
						<p>📅 Setiap Sabtu, 18.00 WIB</p>
					</div>
				</div>
				
				<!-- Worship Team -->
				<div class="bg-gray-50 rounded-3xl p-8 hover:shadow-xl transition-all hover:-translate-y-1">
					<div class="w-16 h-16 bg-slate-600 rounded-2xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path>
						</svg>
					</div>
					<h3 class="text-2xl font-black text-gray-800 mb-3">Worship Team</h3>
					<p class="text-gray-600 mb-4">Tim pujian dan penyembahan yang berdedikasi untuk memimpin jemaat dalam worship.</p>
					<div class="text-sm text-slate-600 font-medium">
						<p>📅 Latihan: Rabu, 19.00 WIB</p>
					</div>
				</div>
				
				<!-- Multimedia -->
				<div class="bg-gray-50 rounded-3xl p-8 hover:shadow-xl transition-all hover:-translate-y-1">
					<div class="w-16 h-16 bg-slate-600 rounded-2xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
						</svg>
					</div>
					<h3 class="text-2xl font-black text-gray-800 mb-3">Multimedia</h3>
					<p class="text-gray-600 mb-4">Tim multimedia yang bertanggung jawab atas visual, audio, dan teknologi ibadah.</p>
					<div class="text-sm text-slate-600 font-medium">
						<p>📅 Koordinasi: Minggu, 06.00 WIB</p>
					</div>
				</div>
				
				<!-- Sekolah Minggu -->
				<div class="bg-gray-50 rounded-3xl p-8 hover:shadow-xl transition-all hover:-translate-y-1">
					<div class="w-16 h-16 bg-slate-600 rounded-2xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
						</svg>
					</div>
					<h3 class="text-2xl font-black text-gray-800 mb-3">Sekolah Minggu</h3>
					<p class="text-gray-600 mb-4">Pelayanan anak-anak untuk mengajar kebenaran dengan cara yang menyenangkan.</p>
					<div class="text-sm text-slate-600 font-medium">
						<p>📅 Setiap Minggu, 07.00 WIB</p>
					</div>
				</div>
				
				<!-- Doa Syafaat -->
				<div class="bg-gray-50 rounded-3xl p-8 hover:shadow-xl transition-all hover:-translate-y-1">
					<div class="w-16 h-16 bg-slate-600 rounded-2xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
						</svg>
					</div>
					<h3 class="text-2xl font-black text-gray-800 mb-3">Doa Syafaat</h3>
					<p class="text-gray-600 mb-4">Tim doa yang setia berdoa untuk kebutuhan jemaat dan bangsa.</p>
					<div class="text-sm text-slate-600 font-medium">
						<p>📅 Setiap Selasa, 19.00 WIB</p>
					</div>
				</div>
				
				<!-- Connect Group -->
				<div class="bg-gray-50 rounded-3xl p-8 hover:shadow-xl transition-all hover:-translate-y-1">
					<div class="w-16 h-16 bg-slate-600 rounded-2xl flex items-center justify-center mb-6">
						<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
						</svg>
					</div>
					<h3 class="text-2xl font-black text-gray-800 mb-3">Connect Group</h3>
					<p class="text-gray-600 mb-4">Kelompok kecil untuk fellowship yang lebih dalam dan saling menguatkan.</p>
					<div class="text-sm text-slate-600 font-medium">
						<p>📅 Berbagai waktu yang tersedia</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
