---

<!-- Sticky Navbar -->
<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-900/90 backdrop-blur-md border-b border-gray-800">
	<div class="container mx-auto px-6">
		<div class="flex items-center justify-between h-16">
			<!-- Logo -->
			<a href="/" class="flex items-center gap-2">
				<div class="w-10 h-10 bg-gradient-to-br from-slate-600 to-slate-700 rounded-xl flex items-center justify-center">
					<img src="/logo-haleluya-nobg.png" alt="Logo" class="w-8 h-8" />
				</div>
				<span class="text-white font-bold text-xl hidden sm:block">GPdI Haleluya</span>
			</a>
			
			<!-- Desktop Navigation -->
			<div class="hidden md:flex items-center gap-8">
				<a href="/" class="text-gray-300 hover:text-white transition-colors font-medium">Beranda</a>
				<a href="/tentang" class="text-gray-300 hover:text-white transition-colors font-medium">Tentang</a>
				<a href="/jadwal" class="text-gray-300 hover:text-white transition-colors font-medium">Jadwal</a>
				<a href="/pelayanan" class="text-gray-300 hover:text-white transition-colors font-medium">Pelayanan</a>
				<a href="/rayon" class="text-gray-300 hover:text-white transition-colors font-medium">Rayon</a>
				<a href="/event" class="text-gray-300 hover:text-white transition-colors font-medium">Event</a>
				<a href="/galeri" class="text-gray-300 hover:text-white transition-colors font-medium">Galeri</a>
				<a href="#lokasi" class="text-gray-300 hover:text-white transition-colors font-medium">Lokasi</a>
			</div>
			
			<!-- Mobile Menu Button -->
			<button id="mobile-menu-button" class="md:hidden text-white p-2">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
			</button>
		</div>
		
		<!-- Mobile Menu -->
		<div id="mobile-menu" class="hidden md:hidden pb-4">
			<div class="flex flex-col gap-4">
				<a href="/" class="text-gray-300 hover:text-white transition-colors font-medium">Beranda</a>
				<a href="/tentang" class="text-gray-300 hover:text-white transition-colors font-medium">Tentang</a>
				<a href="/jadwal" class="text-gray-300 hover:text-white transition-colors font-medium">Jadwal</a>
				<a href="/pelayanan" class="text-gray-300 hover:text-white transition-colors font-medium">Pelayanan</a>
				<a href="/rayon" class="text-gray-300 hover:text-white transition-colors font-medium">Rayon</a>
				<a href="/event" class="text-gray-300 hover:text-white transition-colors font-medium">Event</a>
				<a href="/galeri" class="text-gray-300 hover:text-white transition-colors font-medium">Galeri</a>
				<a href="#lokasi" class="text-gray-300 hover:text-white transition-colors font-medium">Lokasi</a>
			</div>
		</div>
	</div>
</nav>

<script>
	const mobileMenuButton = document.getElementById('mobile-menu-button');
	const mobileMenu = document.getElementById('mobile-menu');
	
	mobileMenuButton?.addEventListener('click', () => {
		mobileMenu?.classList.toggle('hidden');
	});
</script>
